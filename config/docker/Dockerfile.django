FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl git libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY config/docker/requirements.django.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

